# Frontend Dockerfile for Local Development
# Using Debian-based Node to avoid Alpine/musl Rollup issues
FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
# Note: Dependencies will be installed in the Docker volume
# This is just for the initial image
RUN npm install

# Copy source files (will be overridden by volume mount in docker-compose)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Start Vite dev server with host flag to allow external connections
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
