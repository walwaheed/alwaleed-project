# Production Environment Variables Template
# Copy this file to .env and fill in your actual values

# =====================================
# Supabase Configuration (REQUIRED)
# =====================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# =====================================
# Paylink Payment Gateway (REQUIRED)
# =====================================
PAYLINK_APP_ID=APP_ID_1234567890
PAYLINK_SECRET_KEY=your-secret-key-uuid-format
PAYLINK_TEST_MODE=false

# =====================================
# Application URLs
# =====================================
FRONTEND_URL=https://yourdomain.com

# =====================================
# Server Configuration
# =====================================
NODE_ENV=production
PORT=5000

# =====================================
# CloudPrinter (Optional)
# =====================================
CLOUDPRINTER_API_KEY=your-cloudprinter-api-key

# =====================================
# Security (Optional but Recommended)
# =====================================
# Add your JWT secret if using custom auth
# JWT_SECRET=your-super-secret-jwt-key

# =====================================
# Logging (Optional)
# =====================================
# LOG_LEVEL=info
# ENABLE_ACCESS_LOG=true
