PORT=5000
NODE_ENV=development

# ================================
# Docker & Traefik Configuration
# ================================
# Production app domain (e.g., app.yourdomain.com)
APP_DOMAIN=app.yourdomain.com

# Development app domain (e.g., dev.yourdomain.com)
APP_DEV_DOMAIN=dev.yourdomain.com

# SSL email for Let's Encrypt
SSL_EMAIL=your-email@example.com

# n8n Configuration
SUBDOMAIN=n8n
DOMAIN_NAME=yourdomain.com
GENERIC_TIMEZONE=UTC

# ================================
# Supabase Configuration
# ================================
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ================================
# CloudPrinter Configuration
# ================================
CLOUD_PRINTER_KEY=your_cloudprinter_api_key_here

# ================================
# App Configuration
# ================================
# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
PAYLINK_TEST_MODE=true
