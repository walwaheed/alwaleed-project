# ==============================================
# EXAMPLE ENVIRONMENT VARIABLES FOR LOCAL TESTING
# ==============================================
# Copy this file to .env and fill in your actual values
# cp .env.local.example .env

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Get these from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ==============================================
# PAYLINK CONFIGURATION
# ==============================================
# Get these from your Paylink dashboard

PAYLINK_APP_ID=your-app-id
PAYLINK_SECRET_KEY=your-secret-key

# IMPORTANT: Set to 'true' for local testing, 'false' for production
PAYLINK_TEST_MODE=true

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================

# Frontend URL
# Local: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Node environment
# Options: development, production
NODE_ENV=development

# Backend port
PORT=5000

# ==============================================
# OPTIONAL CONFIGURATION
# ==============================================

# Add any other environment variables your app needs below
# Examples:
# JWT_SECRET=your-jwt-secret
# SESSION_SECRET=your-session-secret
# LOG_LEVEL=debug
